      "containerId": null,
      "lineHeight": 1.25
    },
    {
      "id": "text_60",
      "type": "text",
      "x": 428,
      "y": 328,
      "width": 236,
      "height": 160,
      "text": "Cards second\n\nintroduce canonical v2\nadd channel and country code\nmove merchant analytics to shared table\nkeep v1 backward compatible\n\nWhy second:\nhigh visibility and reuse value",
      "originalText": "Cards second\n\nintroduce canonical v2\nadd channel and country code\nmove merchant analytics to shared table\nkeep v1 backward compatible\n\nWhy second:\nhigh visibility and reuse value",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
