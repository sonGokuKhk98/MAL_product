    },
    {
      "id": "text_90",
      "type": "text",
      "x": 728,
      "y": 328,
      "width": 236,
      "height": 160,
      "text": "Transfers last\n\nadd the highest-control flow\nattach SLA and freshness monitoring\nretire duplicate downstream tables\nenforce contract tests for changes\n\nWhy last:\nregulatory and beneficiary complexity",
      "originalText": "Transfers last\n\nadd the highest-control flow\nattach SLA and freshness monitoring\nretire duplicate downstream tables\nenforce contract tests for changes\n\nWhy last:\nregulatory and beneficiary complexity",
