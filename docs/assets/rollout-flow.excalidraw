    {
      "id": "text_30",
      "type": "text",
      "x": 128,
      "y": 328,
      "width": 236,
      "height": 160,
      "text": "Bill Payments first\n\npublish canonical v1\ncapture source mappings\nstand up validation harness\nrun in parallel with current flow\n\nWhy first:\nlower volume and simpler risk",
      "originalText": "Bill Payments first\n\npublish canonical v1\ncapture source mappings\nstand up validation harness\nrun in parallel with current flow\n\nWhy first:\nlower volume and simpler risk",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 200125,
      "version": 1,
      "versionNonce": 200126,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
